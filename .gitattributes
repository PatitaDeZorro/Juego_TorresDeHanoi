# ==============================================================================
#  .gitattributes UNIVERSAL — Normalización de EOLs, diffs y merges
# ==============================================================================


# ==============================================================================
# [0] REGLA POR DEFECTO
# ==============================================================================
* text=auto eol=lf


# ==============================================================================
# [1] DOCUMENTACIÓN Y TEXTO PLANO
# ==============================================================================
*.md            text eol=lf
*.markdown      text eol=lf
*.mdx           text eol=lf
*.txt           text eol=lf
*.rst           text eol=lf
*.adoc          text eol=lf
*.asciidoc      text eol=lf
*.org           text eol=lf
LICENSE         text eol=lf
LICENSE.*       text eol=lf
README          text eol=lf
AUTHORS         text eol=lf
CHANGELOG       text eol=lf
CONTRIBUTING    text eol=lf
COPYING         text eol=lf
INSTALL         text eol=lf
NOTICE          text eol=lf


# ==============================================================================
# [2] LaTeX — FUENTES (texto) Y AUXILIARES (no diffeables)
# ==============================================================================
*.tex           text eol=lf
*.bib           text eol=lf
*.cls           text eol=lf
*.sty           text eol=lf
*.dtx           text eol=lf
*.ins           text eol=lf

# Archivos auxiliares: si alguien los versiona accidentalmente,
# al menos no ensucian el diff.
*.aux           text eol=lf -diff
*.bbl           text eol=lf -diff
*.blg           text eol=lf -diff
*.fdb_latexmk   text eol=lf -diff
*.fls           text eol=lf -diff
*.toc           text eol=lf -diff
*.lof           text eol=lf -diff
*.lot           text eol=lf -diff
*.nav           text eol=lf -diff
*.snm           text eol=lf -diff
*.vrb           text eol=lf -diff
*.synctex.gz    binary


